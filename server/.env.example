PORT=5000
FRONTEND_URL=http://localhost:5173

# Database & Admin Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/portfolio?retryWrites=true&w=majority
ADMIN_SECRET=your-random-protected-admin-secret-string

# Email Service Configuration (Option A: Resend - Recommended)
RESEND_API_KEY=re_your_api_key

# Email Service Configuration (Option B: Gmail SMTP fallback)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-16-character-app-password
